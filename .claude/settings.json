{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.go)|Write(*.go)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-go.sh",
            "timeout": 30,
            "statusMessage": "Running golangci-lint..."
          }
        ]
      }
    ]
  }
}
